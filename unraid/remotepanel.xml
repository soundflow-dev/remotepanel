<?xml version="1.0"?>
<Container version="2">
  <Name>RemotePanel</Name>
  <Repository>ghcr.io/soundflow-dev/remotepanel:latest</Repository>
  <Registry>https://github.com/soundflow-dev/remotepanel</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/soundflow-dev/remotepanel/issues</Support>
  <Project>https://github.com/soundflow-dev/remotepanel</Project>
  <Overview>RemotePanel is a self-hosted homelab control panel for SSH/SFTP machines, SMB shares, file transfers, terminal sessions, stats, Wake-on-LAN, power actions, UPS/NUT shutdown automation, backups, audit logs, and network discovery.</Overview>
  <Category>Tools: Network: Productivity:</Category>
  <WebUI>http://[IP]:[PORT:8000]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/soundflow-dev/remotepanel/main/unraid/remotepanel.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/soundflow-dev/remotepanel/main/frontend/public/brand/icon-512.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="WebUI Port" Target="8000" Default="8090" Mode="tcp" Description="RemotePanel web interface port." Type="Port" Display="always" Required="true" Mask="false">8090</Config>
  <Config Name="App Data" Target="/data" Default="/mnt/user/appdata/remotepanel/data" Mode="rw" Description="Persistent RemotePanel data." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/remotepanel/data</Config>
  <Config Name="APP_SECRET_KEY" Target="APP_SECRET_KEY" Default="" Mode="" Description="Required stable secret used to encrypt saved credentials. Generate with: openssl rand -base64 48" Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="COOKIE_SECURE" Target="COOKIE_SECURE" Default="false" Mode="" Description="Set true only when RemotePanel is served over HTTPS." Type="Variable" Display="advanced" Required="true" Mask="false">false</Config>
  <Config Name="SMB Require Signing" Target="SMB_REQUIRE_SIGNING" Default="true" Mode="" Description="Set false on trusted networks if your SMB server allows unsigned SMB and you want more speed." Type="Variable" Display="advanced" Required="false" Mask="false">true</Config>
</Container>
